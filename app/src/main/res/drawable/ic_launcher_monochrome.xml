<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome layer for Themed Icons (Android 13+).
    Must be a single opaque black vector — Android tints it with the wallpaper color.
    All strokes use fillColor black and full alpha (no strokeColor / strokeAlpha here).
    We draw filled paths that approximate the stroked shapes for monochrome compatibility.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Globe outer ring (filled ring via two circles trick using clip is not easy in VectorDrawable,
         so we use a stroke-only path — monochrome rendering tolerates strokeColor) -->
    <path
        android:pathData="M54,20 A34,34 0 1,0 54.001,20 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#000000"
        android:strokeWidth="2.5"/>

    <!-- Vertical longitude -->
    <path
        android:pathData="M54,20 A16,34 0 1,0 54.001,20 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#000000"
        android:strokeWidth="2.5"/>

    <!-- Equator -->
    <path
        android:pathData="M20,54 L88,54"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#000000"
        android:strokeWidth="2.5"/>

    <!-- Arrow stem -->
    <path
        android:pathData="M54,36 L54,62"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#000000"
        android:strokeWidth="7"
        android:strokeLineCap="round"/>

    <!-- Arrow head -->
    <path
        android:pathData="M42,53 L54,67 L66,53"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#000000"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

</vector>
